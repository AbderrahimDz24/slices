# Exclude files and folders that should not be sent to the Docker build context

# Dependencies
node_modules

# Build outputs and coverage
.dist
/dist
coverage

# Environment files (do not bake secrets into images)
.env
.env.*

# Version control
.git
.gitignore

# IDE/editor folders
.vscode
.idea

# OS artifacts
.DS_Store
Thumbs.db

# Docker local files (compose and helper dir not needed in image context)
docker/
docker-compose.yml

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
